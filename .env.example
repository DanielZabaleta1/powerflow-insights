# Copy to .env for local dev. Never commit the real .env (see .gitignore).

# Gemini API key — Google AI Studio, same project as power-flow-os n8n.
GEMINI_API_KEY=

# Postgres connection string for the insights_readonly role (Fase 1),
# pointed at the Supabase pooler. NEVER use the service_role connection here.
DEMO_DB_URL=

# PostHog Cloud project API key (public, safe for the client bundle).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Used only by db/seed.ts, run once locally — needs write access.
# NOT read by api/ask.ts. Never set this in Vercel.
SEED_DB_URL=
